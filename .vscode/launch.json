{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Go Debugger: Main",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {"POSTGRES_PGBOUNCER_HOST": "localhost"},
            "program": "main.go",
            "args": "--database postgres --duration 1 --batch-size 1 --producers 2 --duplicate-ratio 0 --workers 1  --rows-per-second 1 --queries-per-record 0 --pgbouncer-enabled"
        },
        {
            "name": "Go Debugger: Test",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}"
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "python": ".venv/bin/python",
            "program": "main.py",
            "console": "integratedTerminal",
            "args": "--database postgres   --duration 300 --batch-size 5 --producers 5 --duplicate-ratio 0 --workers 8  --rows-per-second 30 --queries-per-record 0 --query-delay 5000 --ignore-select-errors"
        }
    ]
}
